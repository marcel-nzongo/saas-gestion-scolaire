{
  "name": "@educore/database",
  "version": "0.0.1",
  "description": "Database migrations et configuration pour EduCore",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "migrate": "knex --knexfile src/config/knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile src/config/knexfile.ts migrate:rollback",
    "seed": "knex --knexfile src/config/knexfile.ts seed:run",
    "build": "tsc"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0"
  }
}

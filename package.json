{
  "name": "educore",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "Plateforme de gestion scolaire multi-tenant",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "pnpm --filter @educore/database migrate",
    "db:seed": "pnpm --filter @educore/database seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
